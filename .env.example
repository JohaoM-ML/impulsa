# Google Vision (OCR)
GOOGLE_VISION_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Vercel — resumen diario por WhatsApp (header Authorization: Bearer ...)
CRON_SECRET=

# Chatbot WhatsApp — secreto compartido con n8n (header x-n8n-secret)
N8N_WEBHOOK_SECRET=

# n8n MCP (solo Cursor / administración de workflows)
N8N_API_URL=https://impulsa12121.app.n8n.cloud
N8N_API_KEY=

# Twilio — descargar audio de WhatsApp (solo server-side en Vercel, NO en n8n)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Fallback si no usas API Key:
# TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

