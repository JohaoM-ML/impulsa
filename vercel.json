{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/resumen-diario",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/pedido-proactivo",
      "schedule": "0 13 * * *"
    }
  ]
}
